#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

show_help() {
  cat <<'EOF'
Usage: ./start <command> [args...]

Commands:
  server      Start the inter-agent server (default when no command given)
  connect     Connect an agent session to the bus
  send        Send a direct message
  broadcast   Broadcast a message to all sessions
  list        List connected sessions
  status      Show server status
  shutdown    Shut down the server
EOF
}

case "${1:-}" in
  -h|--help)
    show_help
    exit 0
    ;;
esac

CMD="${1:-server}"
[[ -n "$1" ]] && shift

case "$CMD" in
  server)
    exec uv run inter-agent-server "$@"
    ;;
  connect)
    exec uv run inter-agent-pi connect "$@"
    ;;
  send)
    exec uv run inter-agent-pi send "$@"
    ;;
  broadcast)
    exec uv run inter-agent-pi broadcast "$@"
    ;;
  list)
    exec uv run inter-agent-pi list "$@"
    ;;
  status)
    exec uv run inter-agent-pi status "$@"
    ;;
  shutdown)
    exec uv run inter-agent-pi shutdown "$@"
    ;;
  *)
    echo "Unknown command: $CMD"
    exit 2
    ;;
esac

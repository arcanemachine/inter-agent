#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DOCS="integrations/claude-code/README.md#runtime-setup"
MANAGED_VENV="${INTER_AGENT_CLAUDE_VENV:-$HOME/.claude/data/inter-agent/venv}"
MANAGED_HELPER="$MANAGED_VENV/bin/inter-agent-claude"

expand_path() {
  local value="$1"
  case "$value" in
    "~") printf '%s\n' "$HOME" ;;
    "~/"*) printf '%s/%s\n' "$HOME" "${value#~/}" ;;
    *) printf '%s\n' "$value" ;;
  esac
}

fail() {
  printf '[inter-agent] setup failed: %s. See %s\n' "$1" "$DOCS" >&2
  exit "${2:-127}"
}

# A selected helper may pass the executable-bit check yet still fail to exec when
# its shebang interpreter is gone (a stale or relocated venv). Catch that before
# exec so the failure is a bounded [inter-agent] setup-failed line instead of a
# raw shell error and a bare exit 127 that looks like setup-needed.
verify_helper() {
  local helper="$1"
  local label="$2"
  local shebang rest interp
  shebang="$(head -n1 "$helper" 2>/dev/null || true)"
  case "$shebang" in
    '#!'*)
      rest="${shebang#\#!}"
      rest="${rest#"${rest%%[![:space:]]*}"}"
      interp="${rest%%[[:space:]]*}"
      if [[ -z "$interp" || ! -x "$interp" || -d "$interp" ]]; then
        fail "$label interpreter not executable: $interp (in $helper)"
      fi
      ;;
  esac
}

if [[ "${1:-}" == "bootstrap" ]]; then
  shift
  exec "$SCRIPT_DIR/bootstrap-runtime" "$@"
fi

if [[ -n "${CLAUDE_PLUGIN_OPTION_SECRET:-}" ]]; then
  export INTER_AGENT_SECRET="$CLAUDE_PLUGIN_OPTION_SECRET"
fi

if [[ -n "${INTER_AGENT_CLAUDE_HELPER:-}" ]]; then
  helper="$(expand_path "$INTER_AGENT_CLAUDE_HELPER")"
  if [[ ! -x "$helper" || -d "$helper" ]]; then
    fail "helper from INTER_AGENT_CLAUDE_HELPER not executable: $helper"
  fi
  verify_helper "$helper" "INTER_AGENT_CLAUDE_HELPER"
  exec "$helper" "$@"
fi

if [[ -n "${CLAUDE_PLUGIN_OPTION_PROJECT_PATH:-}" ]]; then
  project_path="$(expand_path "$CLAUDE_PLUGIN_OPTION_PROJECT_PATH")"
  helper="$project_path/.venv/bin/inter-agent-claude"
  if [[ ! -x "$helper" || -d "$helper" ]]; then
    fail "configured project_path helper not found: $helper"
  fi
  verify_helper "$helper" "project_path"
  exec "$helper" "$@"
fi

if [[ -x "$MANAGED_HELPER" && ! -d "$MANAGED_HELPER" ]]; then
  verify_helper "$MANAGED_HELPER" "managed venv"
  exec "$MANAGED_HELPER" "$@"
fi

path_helper="$(command -v inter-agent-claude || true)"
if [[ -n "$path_helper" && "$path_helper" != "$SCRIPT_DIR/inter-agent-claude" ]]; then
  verify_helper "$path_helper" "PATH"
  exec "$path_helper" "$@"
fi

printf '[inter-agent] setup needed: run /inter-agent bootstrap. See %s\n' "$DOCS" >&2
exit 127

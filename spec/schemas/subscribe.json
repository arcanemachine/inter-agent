{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subscribe",
  "type": "object",
  "required": ["op", "channel"],
  "properties": {
    "op": { "const": "subscribe" },
    "channel": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,39}$",
      "description": "Channel name. The server also applies INTER_AGENT_CHANNEL_NAME_MAX as a UTF-8 byte limit."
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Msg",
  "type": "object",
  "required": ["op", "msg_id", "from", "from_name", "ts"],
  "properties": {
    "op": { "const": "msg" },
    "msg_id": { "type": "string" },
    "from": { "type": "string" },
    "from_name": { "type": "string" },
    "to": { "type": ["string", "null"] },
    "channel": { "type": "string" },
    "text": { "type": "string" },
    "ts": { "type": "string" },
    "custom_type": { "type": "string", "minLength": 1 },
    "payload": {}
  },
  "oneOf": [
    {
      "required": ["text"],
      "description": "Direct, broadcast, or channel text message."
    },
    {
      "required": ["custom_type", "payload"],
      "description": "Custom pass-through message. Custom messages do not include text."
    }
  ],
  "additionalProperties": true
}

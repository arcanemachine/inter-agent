{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ListOk",
  "type": "object",
  "required": ["op", "sessions"],
  "properties": {
    "op": { "const": "list_ok" },
    "sessions": {
      "type": "array",
      "description": "Connected agent sessions sorted by routing name. Control sessions are excluded.",
      "items": {
        "type": "object",
        "required": ["session_id", "name", "label"],
        "properties": {
          "session_id": { "type": "string", "description": "Stable session identifier from hello." },
          "name": { "type": "string", "description": "Routing name used for direct targets." },
          "label": { "type": ["string", "null"], "description": "Optional display-only label." }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

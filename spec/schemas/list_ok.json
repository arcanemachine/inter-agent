{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ListOk",
  "type": "object",
  "required": ["op", "sessions"],
  "properties": {
    "op": { "const": "list_ok" },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["session_id", "name"],
        "properties": {
          "session_id": { "type": "string" },
          "name": { "type": "string" },
          "label": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

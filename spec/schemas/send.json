{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Send",
  "type": "object",
  "required": ["op", "to", "text"],
  "properties": {
    "op": { "const": "send" },
    "to": { "type": "string" },
    "text": {
      "type": "string",
      "description": "Direct message text. The server accepts UTF-8 encoded text bytes up to INTER_AGENT_DIRECT_MAX."
    }
  },
  "additionalProperties": true
}

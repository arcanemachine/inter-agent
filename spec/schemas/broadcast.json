{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Broadcast",
  "type": "object",
  "required": ["op", "text"],
  "properties": {
    "op": { "const": "broadcast" },
    "text": {
      "type": "string",
      "description": "Broadcast message text. The server accepts UTF-8 encoded text bytes up to INTER_AGENT_BROADCAST_MAX."
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChannelsOk",
  "type": "object",
  "required": ["op", "channels"],
  "properties": {
    "op": { "const": "channels_ok" },
    "channels": {
      "type": "array",
      "description": "Active channels sorted by name. Each entry contains the channel name and a sorted list of subscriber routing names.",
      "items": {
        "type": "object",
        "required": ["name", "subscribers"],
        "properties": {
          "name": { "type": "string", "description": "Channel name." },
          "subscribers": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

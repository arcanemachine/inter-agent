{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hello",
  "type": "object",
  "required": ["op", "auth", "role", "session_id", "name", "capabilities"],
  "properties": {
    "op": { "const": "hello" },
    "auth": {
      "type": "object",
      "required": ["method", "client_nonce"],
      "properties": {
        "method": { "const": "hmac-sha256" },
        "client_nonce": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "role": { "enum": ["agent", "control"] },
    "session_id": {
      "type": "string",
      "description": "Client session identifier. Active session IDs must be unique; duplicates are rejected."
    },
    "name": { "type": "string" },
    "label": { "type": ["string", "null"] },
    "capabilities": {
      "type": "object",
      "description": "Client-declared capabilities. Unknown keys are extension declarations and may be ignored by the server.",
      "properties": {
        "core": {
          "type": "object",
          "properties": {
            "version": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

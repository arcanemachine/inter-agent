{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Publish",
  "type": "object",
  "required": ["op", "channel", "text"],
  "properties": {
    "op": { "const": "publish" },
    "channel": {
      "type": "string",
      "description": "Channel name to publish to."
    },
    "text": {
      "type": "string",
      "description": "Publish message text. The server accepts UTF-8 encoded text bytes up to INTER_AGENT_BROADCAST_MAX."
    },
    "from_name": { "type": "string" }
  },
  "additionalProperties": true
}

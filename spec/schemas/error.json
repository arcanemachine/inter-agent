{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Error",
  "type": "object",
  "required": ["op", "code", "message"],
  "properties": {
    "op": { "const": "error" },
    "code": {
      "enum": [
        "PROTOCOL_ERROR",
        "AUTH_FAILED",
        "TOO_MANY_CONNECTIONS",
        "BAD_ROLE",
        "BAD_SESSION",
        "SESSION_TAKEN",
        "BAD_NAME",
        "BAD_LABEL",
        "NAME_TAKEN",
        "UNKNOWN_OP",
        "BAD_TEXT",
        "BAD_FROM_NAME",
        "BAD_CUSTOM_TYPE",
        "TEXT_TOO_LARGE",
        "CUSTOM_PAYLOAD_TOO_LARGE",
        "UNKNOWN_TARGET",
        "AMBIGUOUS_TARGET",
        "BAD_CHANNEL",
        "CHANNEL_LIMIT_REACHED",
        "NOT_SUBSCRIBED",
        "UNKNOWN_CHANNEL"
      ]
    },
    "message": { "type": "string" }
  },
  "additionalProperties": true
}
